# ---------------------------------------------------------------------------
# LMS Bridge environment configuration (copy to .env and fill in)
# ---------------------------------------------------------------------------

# --- Application ---
APP_ENV=development               # development | staging | production
APP_NAME=LMS Bridge
LOG_LEVEL=INFO
API_PORT=8000
# Deployment model:
#   community = single self-hosted institution; launches are NEVER license-gated, no
#               sales/leads surfaces, the institution admin manages everything. (default)
#   hosted    = multi-tenant SaaS run by an operator (platform role, leads, licensing).
DEPLOYMENT_MODE=community

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated list of allowed CORS origins.
# 8080 = the frontend served by docker compose; 5173 = the Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database ---
# Host port to publish the Postgres container on (docker compose). Defaults to 5433
# to avoid clashing with a local Postgres already using 5432.
DB_PORT=5433
# For docker-compose this is set automatically; for local dev sqlite is the default.
DATABASE_URL=postgresql+psycopg://lmsbridge:lmsbridge@localhost:5432/lmsbridge
# DATABASE_URL=sqlite+pysqlite:///./lmsbridge.db

# --- LLM provider ---
# provider-agnostic: mock | anthropic | openai | azure_openai
LLM_PROVIDER=mock
LLM_MODEL=claude-3-5-sonnet-latest
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.3
# Provider credentials (only the selected provider's keys are required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# --- Brightspace integration ---
# adapter: mock | valence
BRIGHTSPACE_ADAPTER=mock
BRIGHTSPACE_BASE_URL=
BRIGHTSPACE_APP_ID=
BRIGHTSPACE_APP_KEY=
BRIGHTSPACE_USER_ID=
BRIGHTSPACE_USER_KEY=

# --- Remediation engine ---
# Score (0-1) at or below which a concept is flagged for remediation
REMEDIATION_TRIGGER_THRESHOLD=0.7
# Mastery score (0-1) required to mark a concept mastered
MASTERY_THRESHOLD=0.85

# --- LTI 1.3 (public hostnames used to build launch/redirect URLs) ---
# LMS Bridge installs INTO your LMS as an LTI 1.3 tool — these must be the tool's
# real, PUBLIC, HTTPS URLs. An LMS will NOT launch http:// or localhost. For a real
# LMS integration set both to the domain you host the tool on, e.g.:
#   TOOL_BASE_URL=https://lms-bridge.your-university.edu
#   FRONTEND_BASE_URL=https://lms-bridge.your-university.edu
# Then register the tool in your LMS using GET <TOOL_BASE_URL>/api/v1/lti/config
# (full per-LMS runbook: docs/INSTALL_LTI.md). localhost is for local preview only.
TOOL_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:8080

# --- Marketing site ---
# API base the marketing site's demo form posts to.
MARKETING_API_BASE_URL=http://localhost:8000/api/v1

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
